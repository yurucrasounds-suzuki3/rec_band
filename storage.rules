rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /songs/{userId}/{songId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /parts/{songId}/{userId}/{partId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
